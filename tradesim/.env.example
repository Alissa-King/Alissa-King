# Supabase — get from Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Alpaca (free paper trading account at alpaca.markets)
# Used for real-time US stock prices via IEX feed
ALPACA_API_KEY=your-alpaca-api-key
ALPACA_SECRET_KEY=your-alpaca-secret-key

# UUID of the bot's Supabase auth user (create via SQL editor after setup)
# INSERT INTO auth.users ... or use the Supabase dashboard
BOT_USER_ID=00000000-0000-0000-0000-000000000bot
